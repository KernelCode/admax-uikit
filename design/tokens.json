{
  "$schema": "https://tr.designtokens.org/format/tokens.schema.json",
  "$description": "Admax design tokens (W3C DTCG). Ads-campaign-manager admin kit — sunny amber/gold brand, orange accent, green/red status, off-white canvas, big radii, RTL-ready.",
  "color": {
    "$type": "color",
    "brand": {
      "50": { "$value": "#fff8e6" },
      "100": { "$value": "#ffefc2" },
      "200": { "$value": "#ffe095" },
      "300": { "$value": "#ffcd55" },
      "400": { "$value": "#fbb828" },
      "500": { "$value": "#f59e0b" },
      "600": { "$value": "#e2820a" },
      "700": { "$value": "#b9650a" },
      "800": { "$value": "#934f0e" },
      "900": { "$value": "#78410f" }
    },
    "light": {
      "background": { "$value": "#f5f6f8" },
      "foreground": { "$value": "#1d2231" },
      "card": { "$value": "#ffffff" },
      "muted": { "$value": "#eef0f4" },
      "muted-foreground": { "$value": "#8a92a6" },
      "border": { "$value": "#e9ecf2" },
      "primary": { "$value": "#f59e0b" },
      "primary-foreground": { "$value": "#1d2231" },
      "soft": { "$value": "#fff4d6" },
      "ink": { "$value": "#1d2231" }
    },
    "dark": {
      "background": { "$value": "#0f1117" },
      "foreground": { "$value": "#eef1f7" },
      "card": { "$value": "#181b23" },
      "muted": { "$value": "#20242e" },
      "border": { "$value": "#272c38" },
      "primary": { "$value": "#fbb828" }
    },
    "status": {
      "accent": { "$value": "#ff7a45" },
      "success": { "$value": "#22c55e" },
      "danger": { "$value": "#f7585b" },
      "info": { "$value": "#4c6ef5" },
      "grape": { "$value": "#845ef7" }
    }
  },
  "font": {
    "$type": "fontFamily",
    "display": { "$value": ["Plus Jakarta Sans", "Poppins", "Cairo", "sans-serif"] },
    "sans": { "$value": ["Plus Jakarta Sans", "Inter", "Cairo", "sans-serif"] },
    "mono": { "$value": ["JetBrains Mono", "monospace"] }
  },
  "radius": {
    "$type": "dimension",
    "DEFAULT": { "$value": "0.75rem" },
    "lg": { "$value": "0.875rem" },
    "xl": { "$value": "1.125rem" }
  }
}
